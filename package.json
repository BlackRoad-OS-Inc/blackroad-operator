{
  "name": "@blackroad/operator",
  "version": "0.1.0",
  "description": "BlackRoad CLI operator — the br command",
  "type": "module",
  "bin": {
    "br": "./dist/bin/br.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/bin/br.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ test/ && prettier --check src/ test/",
    "lint:fix": "eslint --fix src/ test/ && prettier --write src/ test/",
    "format": "prettier --write src/ test/",
    "check": "npm run typecheck && npm run lint && npm run test",
    "prepack": "npm run check && npm run build"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "conf": "^13.0.1",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "eslint": "^10.0.2",
    "prettier": "^3.4.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.0.5",
    "wrangler": "^4.69.0"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "PROPRIETARY"
}
